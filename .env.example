# ── Supabase ──────────────────────────────────────────────
# Settings > API no painel do Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# ── Pluggy (Open Finance Brasil) — https://dashboard.pluggy.ai ──
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=

# ── Câmbio / email (próximos passos) ──
RESEND_API_KEY=
EXCHANGERATE_API_KEY=

# Banco MCP (alternativa ao Pluggy) — https://banco.mcp.ai (plano Plus/Unlimited p/ API)
BANCOMCP_API_KEY=
BANCOMCP_BASE_URL=https://api.mcp.ai

# Open Finance liberado só para estes e-mails (single-tenant). Vírgula separa.
OPENFINANCE_ALLOWED_EMAILS=

# Admins do app (vírgula separa)
ADMIN_EMAILS=

# Stripe (pagamentos) — dashboard.stripe.com (use chaves de teste primeiro)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=
# Service role do Supabase (Settings > API) — usada SÓ no webhook (server)
SUPABASE_SERVICE_ROLE_KEY=
# URL pública do app (para success/cancel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Segredo do cron de sincronização (defina um valor forte)
CRON_SECRET=
